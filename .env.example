# ===== LLM API Configuration =====
# Option A: Anthropic Claude (recommended)
#   Get your key at https://console.anthropic.com/
#   Key starts with sk-ant-
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=claude-sonnet-4-20250514

# Option B: OpenAI-compatible API (e.g. Alibaba Qwen via DashScope)
#   Uncomment and set LLM_BASE_URL for OpenAI-compatible providers
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# ===== Zep Memory Graph =====
# Free tier available at https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== FRED Economic Data (for Broker Trends) =====
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ===== Accelerated LLM (optional) =====
# Secondary LLM for parallelized workloads. Omit these lines entirely if not used.
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
